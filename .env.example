# ── Doflow Environment Variables ────────────────────────────
# Copy this file to .env and fill in real values before running docker-compose.
# All fields are REQUIRED in production — no defaults are provided
# to avoid silent misconfiguration.

# --- Postgres ---
POSTGRES_USER=doflow
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=doflow

# --- JWT ---
# Generate with: openssl rand -hex 64
JWT_SECRET=change-me-to-a-64-char-random-hex-string

# --- Public URLs ---
PUBLIC_API_URL=https://api.yourdomain.com/api
APP_BASE_URL=https://app.yourdomain.com

# --- Google OAuth ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://api.yourdomain.com/api/auth/google/callback

# --- CORS whitelist (comma-separated) ---
CORS_ORIGINS=https://app.yourdomain.com
CORS_PUBLIC_ORIGINS=

# --- SMTP (optional, for welcome/reset emails) ---
MAIL_FROM=noreply@yourdomain.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
